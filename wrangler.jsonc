{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "url-shortener",
  "main": "src/index.ts",
  "compatibility_date": "2025-06-15",
  "observability": {
    "enabled": true
  },

  // Custom domain. Route maps cq.fyi (and any path) to this Worker.
  // Requires cq.fyi to be an active zone in your Cloudflare account.
  "routes": [
    { "pattern": "cq.fyi", "custom_domain": true }
  ],

  // D1 = source of truth (durable, 30-day Time Travel restore, SQL listing/analytics).
  // Replace database_id after `wrangler d1 create url-shortener`.
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "url-shortener",
      "database_id": "REPLACE_WITH_D1_DATABASE_ID"
    }
  ],

  // KV namespaces. Replace each id after creating them:
  //   wrangler kv namespace create LINKS_CACHE
  //   wrangler kv namespace create AUTH
  "kv_namespaces": [
    {
      // Hot read cache for fast edge redirects.
      "binding": "LINKS_CACHE",
      "id": "REPLACE_WITH_LINKS_CACHE_KV_ID"
    },
    {
      // Sessions + short-lived WebAuthn / OAuth challenges.
      "binding": "AUTH",
      "id": "REPLACE_WITH_AUTH_KV_ID"
    }
  ],

  "vars": {
    // Public base used when building short URLs.
    "BASE_URL": "https://cq.fyi",
    // Only this Google account may sign in.
    "OWNER_EMAIL": "alfredwesterveld@gmail.com",
    // Google OAuth client id is public; fill after creating the OAuth client.
    // Leave empty to disable Google sign-in (passkey still works).
    "GOOGLE_CLIENT_ID": ""
  }

  // Secret (NOT in this file). Only needed for Google sign-in:
  //   wrangler secret put GOOGLE_CLIENT_SECRET
}
